{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-native",
    "target": "es2017",
    "lib": ["es2017", "es2020", "es2022", "dom"],
    "types": ["react-native", "jest", "node"]
  },
  "include": ["src/**/*", "index.js", "App.tsx", "*.ts", "*.tsx", "__tests__/**/*"]
}
