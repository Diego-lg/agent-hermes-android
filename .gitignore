# ── Build artifacts (everything generated by gradle) ──
android/.gradle/
android/build/
android/app/build/
android/app/release/
android/app/captures/
android/local.properties
android/captures/
android/.idea/
android/*.iml
android/app/*.iml

# CMake / NDK build cache (the big one — ~hundreds of MB)
android/app/.cxx/
android/app/.ninja_*

# Generated JS bundle (we don't ship this — the app loads it from Metro at dev time)
android/app/src/main/assets/index.android.bundle
android/app/src/main/res/drawable-*/

# ── iOS (not built yet but ignored for future) ────
ios/Pods/
ios/build/
ios/Podfile.lock
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/

# ── Tests / coverage ──────────────────────────────
coverage/
*.lcov
*.tsbuildinfo

# ── Env / secrets ──────────────────────────────────
.env
.env.local
.env.*.local
keystore.properties
*.keystore
!android/app/debug.keystore
